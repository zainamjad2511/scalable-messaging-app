SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
PORT=4000
NODE_ID=node-1
# API on host + Redis in Docker Compose (host port 6380 avoids clashing with local Redis on 6379):
# REDIS_URL=redis://localhost:6380
# API on host + your own Redis on 6379:
REDIS_URL=redis://localhost:6379
# In Docker, Compose sets REDIS_URL=redis://redis:6379 (service name, internal port).
