{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "commonjs",
    "moduleResolution": "node"
  },
  "ts-node": {
    "ignore": ["node_modules/(?!@repo/)"],
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node"
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
