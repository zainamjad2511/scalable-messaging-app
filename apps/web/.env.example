# WebSocket entrypoint (see SETUP.md — pick the line that matches how you run the API).

# Docker Compose + Nginx on the host (WS upgrade proxied on port 80) — same as useWebSocket default:
# NEXT_PUBLIC_WS_URL=ws://localhost

# API only via npm on this machine (apps/api PORT, usually 4000):
# NEXT_PUBLIC_WS_URL=ws://localhost:4000
